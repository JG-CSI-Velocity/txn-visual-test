import matplotlib.pyplot as plt
import seaborn as sns

def plot_top_bank_threats_spend_growth_thin(
    threat_df,
    title="Top 5 Bank Threats: Spend per Account vs Growth",
    top_n=5
):
    """
    Thin, clean scatter chart for bank threats:

      - x-axis: spend per account
      - y-axis: 6-month growth rate
      - color: category
      - label: bank name
      - legend: horizontal along the bottom
      - compact / low height for slide embedding
    """

    if threat_df is None or threat_df.empty:
        print("No threat data available to plot.")
        return

    # Top N by threat_score (we don't display threat_score, just use it to rank)
    plot_df = (
        threat_df
        .copy()
        .sort_values('threat_score', ascending=False)
        .head(top_n)
    )

    # Spend per account (guard for divide-by-zero)
    plot_df['spend_per_account'] = plot_df.apply(
        lambda row: row['total_spend'] / row['unique_accounts']
        if row['unique_accounts'] > 0 else 0,
        axis=1
    )

    # Human-friendly category labels
    plot_df['category_label'] = (
        plot_df['category']
        .astype(str)
        .str.replace('_', ' ')
        .str.title()
    )

    # ---- Visual style: bold fonts, no grid, thinner figure ----
    plt.rcParams['font.size'] = 10
    plt.rcParams['font.weight'] = 'bold'
    plt.rcParams['axes.labelweight'] = 'bold'
    plt.rcParams['axes.titleweight'] = 'bold'

    sns.set_style("white")  # no grid background

    # Thinner chart: wide, short
    plt.figure(figsize=(8, 3))

    ax = sns.scatterplot(
        data=plot_df,
        x='spend_per_account',
        y='growth_rate',
        hue='category_label',
        s=100,                 # smaller markers for a tighter look
        alpha=0.85,
        edgecolor='black',
        linewidth=0.7,
        legend=True
    )

    # Remove grid
    ax.grid(False)

    # Titles & axes labels
    ax.set_title(title, fontsize=12, fontweight='bold')
    ax.set_xlabel("Spend per Account ($)", fontsize=10, fontweight='bold')
    ax.set_ylabel("Growth (Last 6 Months, %)", fontsize=10, fontweight='bold')

    # Format axes
    ax.xaxis.set_major_formatter(
        plt.FuncFormatter(lambda x, _: f"${x:,.0f}")
    )
    ax.yaxis.set_major_formatter(
        plt.FuncFormatter(lambda y, _: f"{y:.1f}%")
    )

    # ---- Legend: horizontal strip at bottom ----
    handles, labels = ax.get_legend_handles_labels()
    if labels and labels[0] == 'category_label':
        handles = handles[1:]
        labels = labels[1:]

    legend = ax.legend(
        handles,
        labels,
        title="Category",
        loc='upper center',
        bbox_to_anchor=(0.5, -0.35),  # push further below because fig is short
        ncol=max(1, len(labels)),
        frameon=False
    )
    if legend is not None:
        plt.setp(legend.get_texts(), fontweight='bold', fontsize=9)
        plt.setp(legend.get_title(), fontweight='bold', fontsize=9)

    # ---- Bank labels on points (slightly offset so they don't overlap markers) ----
    for _, row in plot_df.iterrows():
        ax.text(
            row['spend_per_account'],
            row['growth_rate'],
            row['competitor'],
            fontsize=8,
            fontweight='bold',
            ha='center',
            va='bottom',      # just above the point
            y=row['growth_rate'] + 0.3  # small vertical offset (tune if needed)
        )

    plt.tight_layout()
    plt.show()

plot_top_bank_threats_spend_growth_thin(
    threat_df,
    title="Top 5 Bank Threats: Spend per Account vs Growth",
    top_n=5
)
