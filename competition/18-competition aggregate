

# Tag competitors (if not already tagged)
if 'competitor_category' not in combined_df.columns:
    combined_df = tag_competitors(combined_df, merchant_col='merchant_consolidated')

competitor_txns = combined_df[combined_df['competitor_category'].notna()]

print("=" * 120)
print(" " * 40 + "M6A-3: COMPETITOR DETECTION SUMMARY")
print("=" * 120)

if len(competitor_txns) == 0:
    print("\nNo competitor transactions found")
else:
    total_comp_txns = len(competitor_txns)
    total_comp_spend = competitor_txns['amount'].sum()
    total_comp_accounts = competitor_txns['primary_account_num'].nunique()
    total_spend = combined_df['amount'].sum()
    total_accounts = combined_df['primary_account_num'].nunique()

    print(f"\nSearched {len(combined_df):,} transactions")
    print(f"  Competitor transactions: {total_comp_txns:,}")
    print(f"  Competitor spend:        ${total_comp_spend:,.2f} ({total_comp_spend / total_spend * 100:.1f}% of total)")
    print(f"  Unique accounts:         {total_comp_accounts:,} ({total_comp_accounts / total_accounts * 100:.1f}% of {total_accounts:,})")
    print(f"  Unique patterns matched: {competitor_txns['competitor_match'].nunique()}")

    # Category breakdown
    print(f"\nBy Category:")
    cat_summary = (
        competitor_txns.groupby('competitor_category')
        .agg(
            transactions=('amount', 'count'),
            spend=('amount', 'sum'),
            accounts=('primary_account_num', 'nunique'),
        )
        .sort_values('spend', ascending=False)
    )
    for cat, row in cat_summary.iterrows():
        label = cat.replace('_', ' ').title()
        print(f"  {label:20s} {row['transactions']:>8,} txns  ${row['spend']:>14,.2f}  ({row['accounts']:,} accounts)")

    # True competitors vs payment ecosystems
    true_spend = competitor_txns[competitor_txns['competitor_category'].isin(TRUE_COMPETITORS)]['amount'].sum()
    eco_spend = competitor_txns[competitor_txns['competitor_category'].isin(PAYMENT_ECOSYSTEMS)]['amount'].sum()
    print(f"\n  True competitor spend:   ${true_spend:>14,.2f}")
    print(f"  Payment ecosystem spend: ${eco_spend:>14,.2f}")

    # Top 10 competitors by spend
    merch_col = 'merchant_consolidated'
    top10 = (
        competitor_txns.groupby(merch_col)
        .agg(
            spend=('amount', 'sum'),
            txns=('amount', 'count'),
            category=('competitor_category', 'first'),
        )
        .sort_values('spend', ascending=False)
        .head(10)
    )
    print(f"\nTop 10 Competitors:")
    for merchant, row in top10.iterrows():
        label = row['category'].replace('_', ' ').title()
        print(f"  {merchant:40s} ${row['spend']:>12,.2f}  {row['txns']:>6,} txns  [{label}]")

    # Unmatched financial discovery
    print(f"\n{'=' * 120}")
    unmatched = discover_unmatched_financial(competitor_txns if 'competitor_category' in combined_df.columns else combined_df)
    if len(unmatched) > 0:
        print(f"\nPotential competitors NOT in config ({len(unmatched)}):")
        display(unmatched.head(20))

print("=" * 120)
