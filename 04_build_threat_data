# ===========================================================================
# Helper: Normalize competitor names (roll-up variants)
# ===========================================================================

def normalize_competitor_name(bank_name: str) -> str:
    """
    Normalize competitor names so variants roll up to a single line.

    Examples:
    - 'GOLDEN 1 CREDIT UNION', 'GOLDEN 1 CU', etc. -> 'GOLDEN 1 CREDIT UNION'
    - 'REVOLUT PAYMENTS', 'REVOLUT*CARD', etc.     -> 'REVOLUT'
    """
    if not isinstance(bank_name, str):
        return bank_name

    name_u = bank_name.upper()

    # Roll up all Golden 1 Credit Union variants
    if "GOLDEN 1" in name_u:
        return "GOLDEN 1 CREDIT UNION"

    # Roll up all Revolut variants
    if "REVOLUT" in name_u:
        return "REVOLUT"

    # Default: keep original
    return bank_name


